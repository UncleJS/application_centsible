# Centsible — Container Environment Variables
# Copy to ~/.config/containers/systemd/.env.centsible

# ── MariaDB ──────────────────────────────────────────────────
MARIADB_ROOT_PASSWORD=change-me-root-password
MARIADB_DATABASE=centsible
MARIADB_USER=centsible
MARIADB_PASSWORD=change-me-db-password

# ── API (mapped from MARIADB_* above) ────────────────────────
DB_USER=centsible
DB_PASSWORD=change-me-db-password
DB_NAME=centsible
JWT_SECRET=change-me-to-random-64-chars
JWT_REFRESH_SECRET=change-me-to-different-random-64-chars
NODE_ENV=production
WEB_URL=http://localhost:10300
RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX=10
GENERAL_RATE_LIMIT_MAX=100
TRUST_PROXY_HEADERS=true
