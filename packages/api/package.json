{
  "name": "@centsible/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "start": "bun run dist/index.js",
    "test": "JWT_SECRET=test-suite-jwt-secret JWT_REFRESH_SECRET=test-suite-refresh-secret bun test",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun run src/db/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "db:seed": "bun run src/db/seed.ts"
  },
  "dependencies": {
    "@centsible/shared": "workspace:*",
    "@elysiajs/cors": "^1.2.0",
    "@elysiajs/jwt": "^1.2.0",
    "@elysiajs/swagger": "^1.2.0",

    "elysia": "^1.2.12",
    "drizzle-orm": "^0.39.3",
    "mysql2": "^3.12.0",
    "argon2": "^0.41.1"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "drizzle-kit": "^0.30.5"
  }
}
